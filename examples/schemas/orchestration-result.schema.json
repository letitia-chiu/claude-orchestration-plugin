{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/letitia-chiu/claude-orchestration-plugin/main/examples/schemas/orchestration-result.schema.json",
  "title": "Canonical orchestration result",
  "description": "Schema v3 is the single canonical result SSOT. The runner supplies immutable provenance from the validated packet, invocation, Git evidence, and provider event metadata. The provider receives only the mechanically extracted $defs.provider_result schema and returns substantive work or review content. The runner validates that content, combines provenance plus provider_result, writes final-result.json, and manifests the bundle.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "provenance",
    "provider_result"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "enum": [3]
    },
    "provenance": {
      "$ref": "#/$defs/provenance"
    },
    "provider_result": {
      "$ref": "#/$defs/provider_result"
    }
  },
  "$defs": {
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "description": "Controller-owned immutable provenance. Providers do not generate, confirm, adjudicate, or modify these fields.",
      "required": [
        "governance_identity",
        "authoritative_plan_sha",
        "candidate_sha",
        "target_repository_head",
        "host_mode",
        "execution_host",
        "host_tier",
        "role",
        "provider",
        "profile",
        "requested_model",
        "reported_model",
        "invocation_path",
        "session_id"
      ],
      "properties": {
        "governance_identity": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "governance_authority",
            "authorization_issuer",
            "acceptance_owner",
            "finding_adjudicator",
            "final_ratifier"
          ],
          "properties": {
            "governance_authority": {
              "type": "string"
            },
            "authorization_issuer": {
              "type": "string"
            },
            "acceptance_owner": {
              "type": "string"
            },
            "finding_adjudicator": {
              "type": "string"
            },
            "final_ratifier": {
              "type": "string"
            }
          }
        },
        "authoritative_plan_sha": {
          "type": "string"
        },
        "candidate_sha": {
          "type": "string"
        },
        "target_repository_head": {
          "type": "string"
        },
        "host_mode": {
          "type": "string",
          "enum": ["claude_hosted", "codex_hosted"]
        },
        "execution_host": {
          "type": "string"
        },
        "host_tier": {
          "type": ["string", "null"]
        },
        "role": {
          "type": "string",
          "enum": ["feasibility_verifier", "implementer", "adversarial_reviewer"]
        },
        "provider": {
          "type": "string",
          "enum": ["codex_cli", "claude_cli"]
        },
        "profile": {
          "type": "string",
          "enum": ["codex_read_only", "codex_workspace_write", "claude_read_only"]
        },
        "requested_model": {
          "type": "string"
        },
        "reported_model": {
          "type": ["string", "null"]
        },
        "invocation_path": {
          "type": "string",
          "enum": ["host_local_cli", "external_cli", "headless_cli"]
        },
        "session_id": {
          "type": ["string", "null"]
        }
      }
    },
    "provider_result": {
      "type": "object",
      "additionalProperties": false,
      "description": "The only schema sent to a provider. It contains substantive result fields and no controller-owned provenance.",
      "required": [
        "verdict",
        "summary",
        "evidence",
        "stop_reason",
        "changed_files",
        "tests",
        "repository_state",
        "findings",
        "observations",
        "suggestions",
        "evidence_gaps"
      ],
      "properties": {
        "verdict": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "stop_reason": {
          "type": ["string", "null"]
        },
        "changed_files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tests": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["command", "status", "output_digest"],
            "properties": {
              "command": {
                "type": "string"
              },
              "status": {
                "type": "string",
                "enum": ["passed", "failed", "skipped"]
              },
              "output_digest": {
                "type": ["string", "null"]
              }
            }
          }
        },
        "repository_state": {
          "type": "object",
          "additionalProperties": false,
          "required": ["pre", "post"],
          "properties": {
            "pre": {
              "type": "object",
              "additionalProperties": false,
              "required": ["head_sha", "status_short"],
              "properties": {
                "head_sha": {
                  "type": "string"
                },
                "status_short": {
                  "type": "string"
                }
              }
            },
            "post": {
              "type": "object",
              "additionalProperties": false,
              "required": ["head_sha", "status_short"],
              "properties": {
                "head_sha": {
                  "type": "string"
                },
                "status_short": {
                  "type": "string"
                }
              }
            }
          }
        },
        "findings": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "severity",
              "violated_requirement",
              "location",
              "repository_evidence",
              "impact",
              "minimal_remediation_scope"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "severity": {
                "type": "string",
                "enum": ["Blocker", "Major", "Minor"]
              },
              "violated_requirement": {
                "type": "string"
              },
              "location": {
                "type": "string"
              },
              "repository_evidence": {
                "type": "string"
              },
              "impact": {
                "type": "string"
              },
              "minimal_remediation_scope": {
                "type": "string"
              }
            }
          }
        },
        "observations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "suggestions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evidence_gaps": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
